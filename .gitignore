## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# DotCover
.idea/
*.dotCover

# Rider / JetBrains IDEs
.idea/
*.sln.iml

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Tye
.tye/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet
*.nupkg
*.snupkg
*.nuspec
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Azure
PublishScripts/
*.Publish.xml
*.pubxml
*.azurePubxml
*.PublishSettings

# Transformed Web.config files
web.config.transform.*

# Windows image file caches
Thumbs.db
ehthumbs.db

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Logs and Databases
*.log
*.ldf
*.mdf
*.sqlite
*.db

# Compiled files
*.dll
*.exe
*.pdb

# Others
*.tmp
*.bak
*.swp

# Node.js (for projects using npm/yarn)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.*

# VS Code
.vscode/

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Backup & temp files
~$*
*.tmp
*.bak
*.old

# Publish outputs
wwwroot/dist/
wwwroot/lib/
